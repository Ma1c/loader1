<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Window">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
    </Style>

    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
    </Style>

    <Style Selector="TextBlock.heading">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource BrushAccentPurple}" />
    </Style>

    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{StaticResource BrushAccentGreen}" />
        <Setter Property="Foreground" Value="#0D1F16" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.primary:pointerover">
        <Setter Property="Background" Value="{StaticResource BrushAccentGreenPressed}" />
    </Style>
    <Style Selector="Button.primary:pressed">
        <Setter Property="Background" Value="{StaticResource BrushAccentGreenPressed}" />
    </Style>

    <Style Selector="TextBox.app-field">
        <Setter Property="Background" Value="#241C36" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="CaretBrush" Value="{StaticResource BrushAccentPurple}" />
    </Style>
    <Style Selector="TextBox.app-field:focus">
        <Setter Property="BorderBrush" Value="{StaticResource BrushAccentPurple}" />
    </Style>

    <Style Selector="ComboBox.app-versions">
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Height" Value="44" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="#241C36" />
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10,8" />
    </Style>
    <Style Selector="ComboBox.app-versions:focus">
        <Setter Property="BorderBrush" Value="{StaticResource BrushAccentPurple}" />
    </Style>
</Styles>
